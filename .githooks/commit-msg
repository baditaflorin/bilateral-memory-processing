#!/usr/bin/env bash
set -euo pipefail

message_file="${1:?commit message file required}"
first_line="$(sed -n '1p' "$message_file")"

if ! printf '%s' "$first_line" | grep -Eq '^(feat|fix|docs|chore|refactor|test|ops|data)(\([a-z0-9._-]+\))?: .+'; then
  echo "Commit message must use Conventional Commits, for example: feat: add local reflection" >&2
  exit 1
fi
