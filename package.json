{
  "name": "bilateral-memory-processing",
  "version": "0.1.0",
  "description": "Private browser-based EMDR-inspired audio journaling with local transcription, reflection prompts, and no trauma uploads.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/baditaflorin/bilateral-memory-processing.git"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && node scripts/clean-pages.mjs && vite build && node scripts/copy-404.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "lint": "eslint . --max-warnings=0",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "smoke": "bash scripts/smoke.sh",
    "audit": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@mlc-ai/web-llm": "^0.2.83",
    "@tanstack/react-query": "^5.90.7",
    "clsx": "^2.1.1",
    "comlink": "^4.4.2",
    "idb": "^8.0.3",
    "lucide-react": "^0.544.0",
    "piper-tts-web": "^1.1.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.9.1",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.38.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.4.0",
    "jiti": "^2.6.1",
    "jsdom": "^27.0.1",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vite": "^7.1.12",
    "vite-plugin-static-copy": "^3.1.4",
    "vitest": "^3.2.4"
  }
}
